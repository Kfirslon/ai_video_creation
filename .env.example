# Copy this file to `.env` and fill in your API keys.

# Required for image generation (Nano Banana / Pixar-style stills).
# Get a free key at https://aistudio.google.com/app/apikey (no credit card).
GEMINI_API_KEY=

# Recommended for text generation (story ideas, scene packs, post metadata).
# Free, fast, separate quota from Gemini. Get a key at https://console.groq.com/keys
# If left blank, the tool falls back to Gemini for text too.
GROQ_API_KEY=

# Optional overrides — defaults are sane.
# GROQ_TEXT_MODEL=llama-3.3-70b-versatile
# GEMINI_TEXT_MODEL=gemini-2.5-flash
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image-preview
# WHISPER_MODEL=base.en
# UI_PORT=5173
